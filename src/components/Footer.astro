---
import property from '../data/property.json';
const { agent } = property;
---

<footer class="bg-midnight-900 border-t border-amber-400/10 py-16 mt-0 mb-16 md:mb-0">
  <div class="max-w-7xl mx-auto px-6 grid grid-cols-1 md:grid-cols-4 gap-10">

    <div class="md:col-span-2">
      <p class="font-display text-amber-400 text-xl tracking-widest uppercase italic mb-4">The Issak Group</p>
      <p class="text-slate-400 text-sm leading-relaxed max-w-sm">
        Beverly Hills luxury real estate — leasing, buying, and AI-powered
        marketing for properties that demand an audience. DRE# 02037760.
      </p>
      <div class="mt-6 flex gap-4">
        <a href={`tel:${agent.phone.replace(/-/g, '')}`} class="text-amber-400 text-sm hover:text-amber-300 transition-colors">
          {agent.phone}
        </a>
        <span class="text-midnight-700">|</span>
        <a href={`mailto:${agent.email}`} class="text-amber-400 text-sm hover:text-amber-300 transition-colors">
          {agent.email}
        </a>
      </div>
    </div>

    <div>
      <p class="text-xs tracking-widest uppercase text-slate-500 mb-5">Navigate</p>
      <nav class="flex flex-col gap-3">
        {[['Home','/'],['Property','/property'],['Gallery','/gallery'],['⚽ FIFA 2026','/fifa-world-cup-2026-los-angeles-rental'],['Beverly Hills','/beverly-hills-luxury-rentals'],['Market Report','/beverly-hills-market-report'],['Services','/services'],['Results','/results'],['FAQ','/faq'],['Apply to Rent','/apply'],['Contact','/contact']].map(([label,href]) => (
          <a href={href} class="text-sm text-slate-400 hover:text-amber-400 transition-colors">{label}</a>
        ))}
      </nav>
    </div>

    <div>
      <p class="text-xs tracking-widest uppercase text-slate-500 mb-5">Listing Agent</p>
      <div class="space-y-2 text-sm text-slate-400">
        <p class="text-white font-medium">{agent.name}</p>
        <p>DRE# {agent.dre}</p>
        <p class="mt-3">{agent.company}</p>
        <p>DRE# {agent.companyDre}</p>
        <p class="mt-3">{agent.phone}</p>
        <p>{agent.email}</p>
      </div>
    </div>
  </div>

  <div class="max-w-7xl mx-auto px-6 mt-12 pt-6 border-t border-white/5 flex flex-col md:flex-row justify-between gap-3 text-xs text-slate-600">
    <p>Broker/Agent does not guarantee accuracy of square footage, lot size, or other property information. Tenant to independently verify all details. Some images on this site are AI-generated renderings for illustrative purposes only and do not represent the actual property at 9432 Oakmore Rd.</p>
    <div class="flex items-center gap-4 shrink-0 flex-wrap justify-end">
      <span class="inline-flex items-center gap-1.5 border border-amber-400/30 bg-amber-400/5 px-3 py-1 text-[11px] tracking-widest uppercase text-amber-400">
        <span class="w-1.5 h-1.5 bg-amber-400 rounded-full animate-pulse"></span>
        Powered by Claude AI
      </span>
      <p>© {new Date().getFullYear()} The Issak Group — Beverly Hills Luxury Real Estate</p>
    </div>
  </div>
</footer>
