---
import Layout from '../layouts/Layout.astro';
import property from '../data/property.json';

const { agent } = property;

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "RealEstateAgent",
  "name": agent.name,
  "telephone": agent.phone,
  "email": agent.email,
  "identifier": `DRE# ${agent.dre}`,
  "worksFor": {
    "@type": "Organization",
    "name": agent.company,
    "identifier": `DRE# ${agent.companyDre}`
  }
};
---

<Layout
  title="Daniel Issak — Beverly Hills Luxury Real Estate Agent | The Issak Group"
  description="Daniel Issak, DRE# 02037760. Beverly Hills luxury real estate agent specializing in executive rentals, gated estates, and AI-powered property marketing. The Issak Group — Real Estate Source Inc."
  jsonLd={jsonLd}
>
  <!-- Agent Hero -->
  <section class="relative py-24 overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-b from-midnight-950 via-midnight-900 to-midnight-950"></div>
    <div class="absolute inset-0 opacity-5" style="background: radial-gradient(ellipse at 50% 0%, #fbbf24 0%, transparent 65%);"></div>
    <div class="relative z-10 max-w-4xl mx-auto px-6">
      <div class="flex flex-col md:flex-row gap-10 items-center md:items-start">
        <!-- Headshot placeholder — replace src with actual photo path e.g. /images/daniel-issak.jpg -->
        <div class="shrink-0">
          <div class="w-40 h-40 md:w-48 md:h-48 rounded-full bg-midnight-800 border-2 border-amber-400/40 flex items-center justify-center overflow-hidden">
            <!-- Swap this div for: <img src="/images/daniel-issak.jpg" alt="Daniel Issak — Beverly Hills luxury real estate agent" class="w-full h-full object-cover" /> -->
            <svg class="w-20 h-20 text-amber-400/30" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M10 9a3 3 0 100-6 3 3 0 000 6zm-7 9a7 7 0 1114 0H3z" clip-rule="evenodd"/>
            </svg>
          </div>
          <div class="mt-3 text-center">
            <span class="text-xs text-slate-600">Add headshot → /images/daniel-issak.jpg</span>
          </div>
        </div>
        <div class="text-center md:text-left">
          <p class="text-amber-400 text-xs tracking-[0.4em] uppercase mb-3">The Issak Group · Listing Agent</p>
          <h1 class="font-display text-4xl md:text-5xl text-white mb-2">{agent.name}</h1>
          <p class="text-slate-400 mb-6">DRE# {agent.dre} · {agent.company}</p>
          <blockquote class="border-l-2 border-amber-400 pl-5 text-slate-300 italic text-lg leading-relaxed max-w-xl mb-8">
            "Beverly Hills luxury rentals move in hours when they're priced right and presented well. Every listing I take gets a dedicated site, professional media, and AI-powered visibility from day one."
          </blockquote>
          <div class="flex flex-wrap gap-3 justify-center md:justify-start">
            <div class="glass px-5 py-3 text-center">
              <p class="text-amber-400 font-display text-xl">Beverly Hills</p>
              <p class="text-slate-500 text-xs mt-0.5">Primary Market</p>
            </div>
            <div class="glass px-5 py-3 text-center">
              <p class="text-amber-400 font-display text-xl">Luxury</p>
              <p class="text-slate-500 text-xs mt-0.5">$15K–$75K+/mo</p>
            </div>
            <div class="glass px-5 py-3 text-center">
              <p class="text-amber-400 font-display text-xl">AI-First</p>
              <p class="text-slate-500 text-xs mt-0.5">Marketing Stack</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="max-w-4xl mx-auto px-6 py-20">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-12 items-start">
      <div class="bg-charcoal/5 border border-charcoal/10 p-8">
        <p class="text-xs tracking-widest uppercase text-charcoal/40 mb-6">Contact Info</p>
        <dl class="space-y-4 text-sm">
          {[
            ['Name', agent.name],
            ['License', `DRE# ${agent.dre}`],
            ['Brokerage', agent.company],
            ['Brokerage DRE', `DRE# ${agent.companyDre}`],
            ['Cell', agent.phone],
            ['Direct', agent.phoneAlt],
            ['Email', agent.email],
            ['Fax', agent.fax],
          ].map(([label, val]) => (
            <div class="flex justify-between border-b border-charcoal/10 pb-4">
              <dt class="text-charcoal/50">{label}</dt>
              <dd class="font-medium text-charcoal text-right">{val}</dd>
            </div>
          ))}
        </dl>
        <div class="mt-8 flex flex-col gap-3">
          <a href={`tel:${agent.phone.replace(/-/g, '')}`} class="block text-center bg-gold text-charcoal font-bold text-xs tracking-widest uppercase px-6 py-4 hover:bg-gold-light transition-colors">
            Call {agent.phone}
          </a>
          <a href={`mailto:${agent.email}`} class="block text-center border border-charcoal/20 text-charcoal text-xs tracking-widest uppercase px-6 py-4 hover:border-gold hover:text-gold transition-colors">
            Email Agent
          </a>
        </div>
      </div>
      <div class="space-y-6">
        <h2 class="font-serif text-charcoal text-3xl">About the Listing</h2>
        <p class="text-charcoal/60 leading-relaxed">
          This exclusive listing is presented by {agent.name} of {agent.company},
          specializing in luxury residential leasing in the greater Los Angeles market.
        </p>
        <p class="text-charcoal/60 leading-relaxed">
          9432 Oakmore Rd is offered as an exclusive right listing. Showings are by
          appointment only with a minimum 24-hour notice. The listing agent must accompany
          all showings.
        </p>
        <div class="border-l-2 border-gold pl-6 space-y-2">
          <p class="text-sm text-charcoal/50">Application Requirements</p>
          <ul class="text-sm text-charcoal/70 space-y-2">
            <li>CAR rental application</li>
            <li>Full credit report (tenant pays $49.99)</li>
            <li>Proof of income / funds</li>
            <li>Supporting documents — submit as single PDF</li>
            <li>Only complete applications reviewed</li>
          </ul>
        </div>
        <a href="/contact" class="inline-block border-b border-gold text-gold text-xs tracking-widest uppercase pb-1 hover:text-gold-light transition-colors">
          Schedule a Showing →
        </a>
      </div>
    </div>
  </section>

  <section class="bg-charcoal py-12 text-center">
    <p class="text-white/30 text-xs max-w-2xl mx-auto">
      Broker/Agent does not guarantee the accuracy of square footage, lot size, or other information
      concerning the conditions or features of the property provided by the seller or obtained from
      public records or other sources. Tenant is advised to independently verify all information
      through personal inspection and with appropriate professionals.
    </p>
  </section>
</Layout>
