---
import SEO from '../components/SEO.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import ChatWidget from '../components/ChatWidget.astro';

interface Props {
  title: string;
  description: string;
  canonical?: string;
  image?: string;
  jsonLd?: object | object[];
}

const { title, description, canonical, image, jsonLd } = Astro.props;
---

<!doctype html>
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,500;0,600;0,700;1,400;1,500&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet" />
    <SEO {title} {description} {canonical} {image} />
    <!-- Google Analytics GA4 -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-XFG4ZJFKV9"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-XFG4ZJFKV9');
    </script>
    {jsonLd && Array.isArray(jsonLd)
      ? jsonLd.map((schema) => <script type="application/ld+json" set:html={JSON.stringify(schema)} />)
      : jsonLd && <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
    }
    <style>
      * { -webkit-font-smoothing: antialiased; -moz-osx-font-smoothing: grayscale; }
      ::selection { background: #fbbf24; color: #020617; }
      ::-webkit-scrollbar { width: 6px; }
      ::-webkit-scrollbar-track { background: #020617; }
      ::-webkit-scrollbar-thumb { background: #fbbf24; border-radius: 3px; }
      .glass {
        background: rgba(15, 23, 42, 0.6);
        backdrop-filter: blur(20px);
        -webkit-backdrop-filter: blur(20px);
        border: 1px solid rgba(251, 191, 36, 0.15);
      }
      .glass-light {
        background: rgba(30, 41, 59, 0.4);
        backdrop-filter: blur(12px);
        -webkit-backdrop-filter: blur(12px);
        border: 1px solid rgba(255,255,255,0.06);
      }
      .text-gradient {
        background: linear-gradient(135deg, #fbbf24 0%, #fcd34d 50%, #f59e0b 100%);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
      }
      .amber-glow {
        box-shadow: 0 0 30px rgba(251, 191, 36, 0.15), 0 0 60px rgba(251, 191, 36, 0.05);
      }
      .amber-glow-hover:hover {
        box-shadow: 0 0 40px rgba(251, 191, 36, 0.25);
        transition: box-shadow 0.3s ease;
      }
      .line-accent::before {
        content: '';
        display: inline-block;
        width: 2px;
        height: 1em;
        background: #fbbf24;
        margin-right: 12px;
        vertical-align: middle;
      }
    </style>
  </head>
  <body class="bg-midnight-950 text-white font-sans antialiased">
    <Header />
    <main class="pt-16">
      <slot />
    </main>
    <Footer />
    <ChatWidget />

    <!-- WhatsApp Floating Button -->
    <a
      href="https://wa.me/13107700552?text=Hi%20Daniel%2C%20I'm%20interested%20in%209432%20Oakmore%20Rd.%20Please%20share%20availability."
      target="_blank"
      rel="noopener noreferrer"
      aria-label="WhatsApp Daniel Issak"
      class="fixed bottom-24 md:bottom-8 left-5 z-[60] w-14 h-14 bg-green-500 rounded-full flex items-center justify-center shadow-xl hover:bg-green-400 transition-all duration-300 hover:scale-110"
      style="box-shadow: 0 0 20px rgba(34,197,94,0.4);"
    >
      <svg class="w-7 h-7 text-white" fill="currentColor" viewBox="0 0 24 24">
        <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
      </svg>
      <span class="absolute top-0 right-0 w-3 h-3 bg-amber-400 rounded-full border-2 border-midnight-950 animate-pulse"></span>
    </a>

    <!-- Sticky Mobile CTA -->
    <div class="fixed bottom-0 left-0 right-0 z-50 md:hidden p-4 bg-gradient-to-t from-midnight-950 via-midnight-950/90 to-transparent">
      <a
        href="https://calendly.com/theissakgroup/30min"
        target="_blank"
        rel="noopener noreferrer"
        class="block w-full text-center bg-amber-400 text-midnight-950 font-semibold text-sm tracking-widest uppercase py-4 rounded-none amber-glow animate-pulse-slow"
      >
        Book a Private Tour
      </a>
    </div>
  </body>
</html>
