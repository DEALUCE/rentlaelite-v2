---
import Layout from '../layouts/Layout.astro';
import property from '../data/property.json';
import CorporateProximity from '../components/CorporateProximity.astro';
import ExecutiveTimeline from '../components/ExecutiveTimeline.astro';
import NeighborhoodMap from '../components/NeighborhoodMap.astro';

const dna = [
  {
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="w-7 h-7"><path stroke-linecap="round" stroke-linejoin="round" d="M3.75 13.5l10.5-11.25L12 10.5h8.25L9.75 21.75 12 13.5H3.75z"/></svg>`,
    label: 'EV Charging', sub: 'On-site station'
  },
  {
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="w-7 h-7"><path stroke-linecap="round" stroke-linejoin="round" d="M12 3v2.25m6.364.386l-1.591 1.591M21 12h-2.25m-.386 6.364l-1.591-1.591M12 18.75V21m-4.773-4.227l-1.591 1.591M5.25 12H3m4.227-4.773L5.636 5.636"/></svg>`,
    label: 'Steam Sauna', sub: 'Primary suite'
  },
  {
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="w-7 h-7"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z"/></svg>`,
    label: 'Gated Security', sub: 'Ring + auto gate'
  },
  {
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="w-7 h-7"><path stroke-linecap="round" stroke-linejoin="round" d="M12 3c-4.97 0-9 3.185-9 7.5S7.03 18 12 18s9-3.185 9-7.5S16.97 3 12 3zm0 0v15m0-15C9 3 6.5 6.5 6.5 10.5M12 3c3 0 5.5 3.5 5.5 7.5M3 10.5h18"/></svg>`,
    label: 'Heated Pool', sub: 'Gas-heated, filtered'
  },
  {
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="w-7 h-7"><path stroke-linecap="round" stroke-linejoin="round" d="M15.362 5.214A8.252 8.252 0 0112 21 8.25 8.25 0 016.038 7.048 8.287 8.287 0 009 9.6a8.983 8.983 0 013.361-6.867 8.21 8.21 0 003 2.48z"/></svg>`,
    label: "Chef's Kitchen", sub: 'Dual ovens & sinks'
  },
  {
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="w-7 h-7"><path stroke-linecap="round" stroke-linejoin="round" d="M8.25 21v-4.875c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21m0 0h4.5V3.545M12.75 21h7.5V10.75M2.25 21h1.5m18 0h-18M2.25 9l4.5-1.636M18.75 3l-1.5.545m0 6.205l3 1m1.5.5l-1.5-.5M6.75 7.364V3h-3v18m3-13.636l10.5-3.819"/></svg>`,
    label: 'Guest House', sub: '~400 sq ft ADU'
  },
  {
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="w-7 h-7"><path stroke-linecap="round" stroke-linejoin="round" d="M8.288 15.038a5.25 5.25 0 017.424 0M5.106 11.856c3.807-3.808 9.98-3.808 13.788 0M1.924 8.674c5.565-5.565 14.587-5.565 20.152 0M12.53 18.22l-.53.53-.53-.53a.75.75 0 011.06 0z"/></svg>`,
    label: 'Smart Home', sub: 'Multi-zone HVAC + lighting'
  },
  {
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="w-7 h-7"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 12l8.954-8.955c.44-.439 1.152-.439 1.591 0L21.75 12M4.5 9.75v10.125c0 .621.504 1.125 1.125 1.125H9.75v-4.875c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21h4.125c.621 0 1.125-.504 1.125-1.125V9.75M8.25 21h8.25"/></svg>`,
    label: '4,492 Sq Ft', sub: 'Combined living space'
  },
];

const jsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "RealEstateListing",
    "name": "9432 Oakmore Rd — Luxury 5BR Fully Furnished Rental | Beverlywood Los Angeles",
    "description": property.description,
    "url": "https://rentlaelite-v2.theissakgroup.workers.dev",
    "image": [
      `https://rentlaelite-v2.theissakgroup.workers.dev${property.images.hero}`,
      `https://rentlaelite-v2.theissakgroup.workers.dev${property.images.outdoor[0]}`,
      `https://rentlaelite-v2.theissakgroup.workers.dev${property.images.kitchen[0]}`,
      `https://rentlaelite-v2.theissakgroup.workers.dev${property.images.primarySuite[0]}`,
      `https://rentlaelite-v2.theissakgroup.workers.dev${property.images.guestHouse[0]}`
    ],
    "address": {
      "@type": "PostalAddress",
      "streetAddress": property.address.street,
      "addressLocality": property.address.city,
      "addressRegion": property.address.state,
      "postalCode": property.address.zip,
      "addressCountry": "US"
    },
    "geo": { "@type": "GeoCoordinates", "latitude": "34.0503", "longitude": "-118.3847" },
    "numberOfRooms": property.beds,
    "floorSize": { "@type": "QuantitativeValue", "value": property.sqft, "unitCode": "FTK" },
    "offers": {
      "@type": "Offer",
      "price": property.price,
      "priceCurrency": "USD",
      "priceSpecification": { "@type": "UnitPriceSpecification", "price": property.price, "priceCurrency": "USD", "unitText": "MON" }
    },
    "broker": { "@type": "RealEstateAgent", "name": property.agent.name, "telephone": property.agent.phone, "email": property.agent.email }
  },
  {
    "@context": "https://schema.org",
    "@type": "VideoObject",
    "name": property.video.title,
    "description": property.video.description,
    "thumbnailUrl": property.video.thumbnailUrl,
    "uploadDate": "2025-01-22",
    "contentUrl": property.video.url,
    "embedUrl": property.video.embedUrl
  }
];
---

<Layout
  title="Luxury 5BR Fully Furnished Rental Beverlywood LA 90035 | 9432 Oakmore Rd — $29,999/mo"
  description="Gated 5-bed fully furnished luxury compound in Beverlywood, LA 90035. Heated pool, steam sauna, chef's kitchen, detached guest house. $29,999/mo. 30-day minimum. Virtual tour available."
  jsonLd={jsonLd}
>

  <!-- ═══════════════════════════════════════ SCARCITY TICKER -->
  <div class="bg-amber-400 text-midnight-950 py-2.5 px-4 text-center z-50 relative">
    <p class="text-xs font-semibold tracking-[0.3em] uppercase flex items-center justify-center gap-3">
      <span class="w-1.5 h-1.5 bg-midnight-950 rounded-full animate-pulse"></span>
      Limited Availability · 2026 FIFA World Cup Housing Window — Inquire Now
      <span class="w-1.5 h-1.5 bg-midnight-950 rounded-full animate-pulse"></span>
    </p>
  </div>

  <!-- ═══════════════════════════════════════ CINEMATIC HERO -->
  <section class="relative h-screen min-h-[700px] flex items-center overflow-hidden">

    <!-- Ken Burns background -->
    <div class="absolute inset-0 z-0">
      <img
        src={property.images.hero}
        alt="9432 Oakmore Rd aerial — gated luxury compound Beverlywood Los Angeles 90035"
        class="w-full h-full object-cover animate-ken-burns origin-center"
        loading="eager"
        fetchpriority="high"
      />
      <div class="absolute inset-0 bg-gradient-to-r from-midnight-950/95 via-midnight-950/60 to-midnight-950/20"></div>
      <div class="absolute inset-0 bg-gradient-to-t from-midnight-950 via-transparent to-transparent"></div>
    </div>

    <div class="relative z-10 max-w-7xl mx-auto px-6 w-full grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">

      <!-- Left: Hero Copy -->
      <div class="animate-fade-up">
        <p class="text-amber-400 text-xs tracking-[0.4em] uppercase mb-4 flex items-center gap-3">
          <span class="w-8 h-px bg-amber-400"></span>
          Beverlywood · Los Angeles, CA 90035
        </p>
        <!-- Fully Furnished Badge -->
        <div class="inline-flex items-center gap-2 border border-amber-400/40 bg-amber-400/10 px-3 py-1.5 mb-6">
          <svg class="w-3 h-3 text-amber-400" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/></svg>
          <span class="text-amber-400 text-xs font-semibold tracking-widest uppercase">Fully Furnished · Move-In Ready</span>
        </div>
        <h1 class="font-display text-5xl md:text-7xl leading-[1.05] mb-6">
          <span class="text-white">9432</span><br />
          <span class="text-white">Oakmore</span><br />
          <em class="text-gradient not-italic">Compound</em>
        </h1>
        <p class="text-slate-300 text-lg leading-relaxed max-w-md mb-8">
          A gated dual-structure estate in prime Beverlywood — 5 bedrooms, heated pool,
          steam sauna, and a fully independent guest house. Curated luxury furnishings included.
        </p>
        <div class="flex flex-wrap gap-6 mb-10 items-end">
          {[
            ['5', 'Beds'],
            ['6', 'Baths'],
            ['4,492', 'Sq Ft'],
          ].map(([val, label]) => (
            <div class="text-center">
              <p class="font-display text-3xl text-amber-400">{val}</p>
              <p class="text-xs text-slate-500 tracking-widest uppercase">{label}</p>
            </div>
          ))}
          <div class="w-px bg-midnight-700 self-stretch"></div>
          <div>
            <p class="font-display text-3xl text-white">$29,999</p>
            <p class="text-xs text-slate-500 tracking-widest uppercase">Per Month</p>
          </div>
        </div>
        <div class="flex flex-wrap gap-3">
          <a href="/property" class="bg-amber-400 text-midnight-950 font-semibold text-xs tracking-widest uppercase px-8 py-4 hover:bg-amber-300 transition-all duration-300 amber-glow-hover">
            Explore Property
          </a>
          <a href="#video" class="glass text-white text-xs tracking-widest uppercase px-8 py-4 hover:border-amber-400/40 transition-all duration-300 flex items-center gap-2">
            <span class="w-5 h-5 rounded-full border border-amber-400 flex items-center justify-center">
              <svg class="w-2.5 h-2.5 text-amber-400 ml-0.5" fill="currentColor" viewBox="0 0 8 10"><path d="M0 0l8 5-8 5V0z"/></svg>
            </span>
            Video Tour
          </a>
          <!-- WhatsApp CTA -->
          <a
            href="https://wa.me/13107700552?text=I'm%20interested%20in%209432%20Oakmore%20Rd%20rental"
            target="_blank"
            rel="noopener noreferrer"
            class="flex items-center gap-2 border border-green-500/40 bg-green-500/10 text-green-400 text-xs tracking-widest uppercase px-6 py-4 hover:bg-green-500/20 hover:border-green-400 transition-all duration-300"
          >
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
            WhatsApp
          </a>
        </div>
      </div>

      <!-- Right: Glassmorphism Inquiry Card -->
      <div class="hidden lg:block">
        <div class="glass rounded-none p-8 amber-glow max-w-sm ml-auto animate-fade-in">
          <p class="text-amber-400 text-xs tracking-[0.3em] uppercase mb-1">Schedule a Private Showing</p>
          <p class="text-slate-500 text-xs mb-6">24-hr response guaranteed · Fully furnished, move-in ready</p>
          <form class="space-y-4" name="hero-inquiry" method="POST" action="/contact">
            <input type="hidden" name="form-name" value="hero-inquiry" />
            <input
              type="text"
              name="name"
              placeholder="Your Name"
              class="w-full bg-midnight-950/60 border border-slate-700 text-white placeholder-slate-500 px-4 py-3 text-sm focus:outline-none focus:border-amber-400 transition-colors"
            />
            <input
              type="email"
              name="email"
              placeholder="Email Address"
              class="w-full bg-midnight-950/60 border border-slate-700 text-white placeholder-slate-500 px-4 py-3 text-sm focus:outline-none focus:border-amber-400 transition-colors"
            />
            <input
              type="tel"
              name="phone"
              placeholder="Phone Number"
              class="w-full bg-midnight-950/60 border border-slate-700 text-white placeholder-slate-500 px-4 py-3 text-sm focus:outline-none focus:border-amber-400 transition-colors"
            />
            <select
              name="lease-length"
              class="w-full bg-midnight-950/60 border border-slate-700 text-slate-400 px-4 py-3 text-sm focus:outline-none focus:border-amber-400 transition-colors"
            >
              <option value="">Intended Stay</option>
              <option value="30-days">30–60 Days</option>
              <option value="60-days">60–90 Days</option>
              <option value="6-months">6 Months</option>
              <option value="12-months">12+ Months</option>
            </select>
            <button
              type="submit"
              class="w-full bg-amber-400 text-midnight-950 font-semibold text-xs tracking-widest uppercase py-4 hover:bg-amber-300 transition-all duration-300"
            >
              Request Showing
            </button>
          </form>
          <div class="flex items-center justify-center gap-4 mt-5 pt-4 border-t border-white/5">
            <a href="tel:3107700552" class="text-slate-500 text-xs hover:text-amber-400 transition-colors flex items-center gap-1.5">
              <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
              310-770-0552
            </a>
            <span class="text-midnight-700">|</span>
            <a href="https://wa.me/13107700552" target="_blank" rel="noopener noreferrer" class="text-green-500 text-xs hover:text-green-400 transition-colors flex items-center gap-1.5">
              <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
              WhatsApp
            </a>
          </div>
        </div>
      </div>
    </div>

    <!-- Scroll indicator -->
    <div class="absolute bottom-8 left-1/2 -translate-x-1/2 z-10 flex flex-col items-center gap-2 animate-bounce">
      <p class="text-slate-600 text-xs tracking-widest uppercase">Discover</p>
      <svg class="w-4 h-4 text-amber-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 9l-7 7-7-7" />
      </svg>
    </div>
  </section>

  <!-- ═══════════════════════════════════════ TRUST SIGNALS -->
  <section class="bg-midnight-900 border-y border-white/5 py-6">
    <div class="max-w-7xl mx-auto px-6">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-px bg-midnight-800/30">
        {[
          { icon: '◈', label: 'DRE Licensed Agent', sub: 'Daniel Issak · #02037760' },
          { icon: '◉', label: 'MLS Verified', sub: 'MLS# 25594215' },
          { icon: '◈', label: '24-Hr Response', sub: 'Direct agent contact' },
          { icon: '◉', label: 'Real Estate Source Inc.', sub: 'Brokerage DRE #01869619' },
        ].map(({ icon, label, sub }) => (
          <div class="glass-light px-6 py-4 flex items-center gap-4">
            <span class="text-amber-400 text-xl shrink-0">{icon}</span>
            <div>
              <p class="text-white text-xs font-semibold">{label}</p>
              <p class="text-slate-500 text-xs mt-0.5">{sub}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════ PROPERTY DNA -->
  <section class="py-24 bg-midnight-900">
    <div class="max-w-7xl mx-auto px-6">
      <div class="text-center mb-16">
        <p class="text-amber-400 text-xs tracking-[0.4em] uppercase mb-4 flex items-center justify-center gap-3">
          <span class="w-8 h-px bg-amber-400"></span>
          What Sets It Apart
          <span class="w-8 h-px bg-amber-400"></span>
        </p>
        <h2 class="font-display text-4xl md:text-5xl text-white">Property <em class="text-gradient">DNA</em></h2>
      </div>
      <div class="grid grid-cols-2 md:grid-cols-4 gap-px bg-midnight-800/50">
        {dna.map(({ icon, label, sub }) => (
          <div class="glass-light p-8 flex flex-col items-center text-center gap-4 group hover:border-amber-400/20 transition-all duration-500">
            <div class="text-amber-400 group-hover:scale-110 transition-transform duration-300" set:html={icon} />
            <div>
              <p class="text-white font-medium text-sm">{label}</p>
              <p class="text-slate-500 text-xs mt-1">{sub}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════ DIVERSE PHOTO STRIP -->
  <section class="grid grid-cols-5 gap-px bg-midnight-950">
    {[
      { src: property.images.aerial[0], alt: '9432 Oakmore Rd aerial drone view — gated compound Beverlywood' },
      { src: property.images.outdoor[0], alt: 'Heated pool & spa — 9432 Oakmore Rd luxury rental LA' },
      { src: property.images.kitchen[0], alt: "Chef's kitchen with dual ovens — 9432 Oakmore Rd" },
      { src: property.images.primarySuite[0], alt: 'Primary suite with steam sauna — 9432 Oakmore Rd' },
      { src: property.images.guestHouse[0], alt: 'Private guest house ADU — 9432 Oakmore Rd Beverlywood' },
    ].map(({ src, alt }) => (
      <a href="/gallery" class="overflow-hidden block aspect-video">
        <img
          src={src}
          alt={alt}
          class="w-full h-full object-cover opacity-75 hover:opacity-100 hover:scale-105 transition-all duration-700"
          loading="lazy"
        />
      </a>
    ))}
  </section>

  <!-- ═══════════════════════════════════════ DESCRIPTION + LIFESTYLE COPY -->
  <section class="py-28 bg-midnight-950">
    <div class="max-w-7xl mx-auto px-6 grid grid-cols-1 lg:grid-cols-2 gap-20 items-center">
      <div>
        <p class="text-amber-400 text-xs tracking-[0.4em] uppercase mb-4 flex items-center gap-3">
          <span class="w-8 h-px bg-amber-400"></span>
          The Estate
        </p>
        <h2 class="font-display text-4xl md:text-5xl text-white mb-8 leading-tight">
          Designed for Those<br /><em class="text-gradient">Who Demand More</em>
        </h2>
        <p class="text-slate-300 leading-relaxed mb-6 text-base">{property.description}</p>
        <p class="text-slate-400 leading-relaxed text-sm mb-6">
          Delivered fully furnished with curated luxury furnishings — every room staged,
          every detail considered. Arrive with nothing but your schedule.
          Positioned on a quiet tree-lined street in the coveted 90035 corridor —
          minutes from Century City, Beverly Hills, Fox Studios, and Cedars-Sinai.
        </p>
        <div class="grid grid-cols-2 gap-3 mb-10 text-xs">
          {[
            'Italian porcelain + hardwood flooring',
            'Multi-zone HVAC system',
