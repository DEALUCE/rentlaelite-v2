---
import Layout from '../layouts/Layout.astro';

const jsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "RealEstateListing",
    "name": "Luxury Rental Beverlywood — 9432 & 9430 Oakmore Rd",
    "description": "5-bedroom luxury rental compound in Beverlywood, Beverly Hills adjacent. $34,999/month fully furnished. Heated pool, spa, chef's kitchen, guest house.",
    "url": "https://theissakgroup.com/luxury-rental-beverlywood",
    "price": "34999",
    "priceCurrency": "USD",
    "address": {
      "@type": "PostalAddress",
      "streetAddress": "9432 & 9430 Oakmore Rd",
      "addressLocality": "Los Angeles",
      "addressRegion": "CA",
      "postalCode": "90035",
      "addressCountry": "US"
    },
    "numberOfRooms": 5,
    "floorSize": { "@type": "QuantitativeValue", "value": 4492, "unitCode": "FTK" }
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "What is the best luxury rental in Beverlywood?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "9432 & 9430 Oakmore Rd is a gated 5-bedroom luxury compound in Beverlywood (ZIP 90035), Beverly Hills adjacent. At 4,492 sq ft combined with a heated pool, spa, and detached guest house, it is one of the most comprehensively appointed luxury rentals in the 90035 corridor, offered at $34,999/month fully furnished."
        }
      },
      {
        "@type": "Question",
        "name": "What ZIP code is Beverlywood?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Beverlywood is located in ZIP code 90035, in Los Angeles, CA. It is immediately adjacent to Beverly Hills (90210) and within 5 minutes of Beverly Drive, 8 minutes to Century City, and 10 minutes to Cedars-Sinai Medical Center."
        }
      },
      {
        "@type": "Question",
        "name": "How much does a luxury rental in Beverlywood cost per month?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Luxury rental homes in Beverlywood (90035) range from $15,000 to $35,000/month. 9432 & 9430 Oakmore Rd is priced at $34,999/month, fully furnished, for the entire 4,492 sq ft gated compound including a detached guest house."
        }
      }
    ]
  }
];
---

<Layout
  title="Luxury Rental Beverlywood | 5BR Compound $34,999/mo | 9432 Oakmore Rd"
  description="Luxury rental in Beverlywood, Beverly Hills adjacent. 5BR/6BA gated compound, 4,492 sq ft, heated pool, chef's kitchen. $34,999/month fully furnished. Contact Daniel Issak DRE# 02037760."
  jsonLd={jsonLd}
>
  <!-- HERO -->
  <section class="relative py-28 bg-midnight-950 overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-br from-midnight-950 via-midnight-900 to-midnight-950"></div>
    <div class="relative z-10 max-w-4xl mx-auto px-6 text-center">
      <p class="text-amber-400 text-xs tracking-[0.4em] uppercase mb-4">Beverlywood · 90035 · Beverly Hills Adjacent</p>
      <h1 class="font-display text-4xl md:text-5xl text-white leading-tight mb-6">
        Luxury Rental<br /><em class="text-gradient">Beverlywood</em>
      </h1>
      <p class="text-slate-300 text-lg mb-8 max-w-2xl mx-auto leading-relaxed">
        9432 & 9430 Oakmore Rd — a gated 5-bedroom compound with heated pool, guest house, and chef's kitchen. The defining luxury rental in the Beverly Hills corridor.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/contact" class="bg-amber-400 text-midnight-950 text-xs font-semibold tracking-widest uppercase px-8 py-4 hover:bg-amber-300 transition-colors amber-glow-hover">Schedule Showing</a>
        <a href="/property" class="border border-amber-400/40 text-amber-400 text-xs tracking-widest uppercase px-8 py-4 hover:border-amber-400 transition-colors">View Property</a>
      </div>
    </div>
  </section>

  <!-- DEFINITION BLOCK (AI-extractable) -->
  <section class="max-w-4xl mx-auto px-6 py-16">
    <div class="glass p-8 md:p-10">
      <h2 class="font-display text-2xl text-white mb-5">What is a Luxury Rental in Beverlywood?</h2>
      <p class="text-slate-300 leading-relaxed mb-4">
        Beverlywood is an upscale residential neighborhood in Los Angeles (ZIP code 90035), immediately west of Beverly Hills and north of Pico Boulevard. Luxury rentals in Beverlywood are typically gated single-family homes priced at $15,000–$35,000/month, offering Beverly Hills-caliber amenities at a relative value compared to 90210 proper.
      </p>
      <p class="text-slate-400 leading-relaxed mb-4">
        <strong class="text-white">9432 & 9430 Oakmore Rd</strong> is the premier Beverlywood luxury rental available in 2026: a gated compound totaling 4,492 sq ft across a main residence and detached guest house, priced at <strong class="text-white">$34,999/month</strong> fully furnished. The property features a heated pool and spa, steam sauna, chef's kitchen, EV charging, and smart home systems.
      </p>
      <p class="text-slate-400 leading-relaxed">
        Beverlywood's central location places tenants within 5 minutes of Beverly Hills, 8 minutes of Century City and Fox Studios, 10 minutes of Cedars-Sinai, and 15 minutes of Santa Monica and SoFi Stadium — making it ideal for entertainment executives, medical professionals, and international visitors.
      </p>
    </div>
  </section>

  <!-- KEY FACTS -->
  <section class="bg-midnight-900 py-16">
    <div class="max-w-6xl mx-auto px-6">
      <p class="text-xs tracking-widest uppercase text-amber-400 mb-10 text-center">Property Highlights</p>
      <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
        {[
          { val: '5 BR / 6 BA', sub: 'Bedrooms & baths' },
          { val: '4,492 sqft', sub: 'Combined living space' },
          { val: '$34,999/mo', sub: 'Fully furnished' },
          { val: '30 Days', sub: 'Minimum lease' },
          { val: 'Heated Pool', sub: '& spa included' },
          { val: 'Guest House', sub: 'Private entrance · ~400 sqft' },
          { val: '5 Min', sub: 'To Beverly Hills' },
          { val: 'May 2026', sub: 'Available · FIFA window' },
        ].map(({ val, sub }) => (
          <div class="glass p-5 text-center">
            <p class="text-amber-400 font-display text-xl mb-1">{val}</p>
            <p class="text-slate-500 text-xs">{sub}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="max-w-3xl mx-auto px-6 py-20">
    <h2 class="font-display text-2xl text-white mb-8 text-center">Luxury Rental Beverlywood — FAQ</h2>
    <div class="space-y-4">
      {[
        { q: 'What is the best luxury rental in Beverlywood?', a: '9432 & 9430 Oakmore Rd is a gated 5-bedroom, 4,492 sq ft compound with a heated pool, spa, guest house, and chef\'s kitchen — fully furnished at $34,999/month. It is the most comprehensively appointed luxury rental currently available in the Beverlywood / 90035 corridor.' },
        { q: 'What ZIP code is Beverlywood?', a: 'Beverlywood is ZIP code 90035, Los Angeles, CA. It borders Beverly Hills to the east, Century City to the north, and Pico-Robertson to the south.' },
        { q: 'How much does a luxury rental in Beverlywood cost?', a: 'Beverlywood luxury rentals range from $15,000 to $35,000/month. 9432 Oakmore Rd is priced at $34,999/month, fully furnished, for 4,492 sq ft including a detached guest house.' },
        { q: 'Is Beverlywood Beverly Hills adjacent?', a: 'Yes. Beverlywood (90035) directly borders Beverly Hills and is commonly described as "Beverly Hills adjacent." Residents are typically 5 minutes from Beverly Drive and 8 minutes from Beverly Hills proper.' },
      ].map(({ q, a }) => (
        <details class="glass group">
          <summary class="flex items-center justify-between p-6 cursor-pointer list-none">
            <span class="text-white font-medium pr-4">{q}</span>
            <span class="text-amber-400 shrink-0 text-lg group-open:rotate-45 transition-transform">+</span>
          </summary>
          <p class="px-6 pb-6 text-slate-400 leading-relaxed">{a}</p>
        </details>
      ))}
    </div>
  </section>

  <!-- CTA -->
  <section class="py-16 bg-midnight-900 text-center">
    <div class="max-w-xl mx-auto px-6">
      <p class="text-xs tracking-widest uppercase text-amber-400 mb-4">Available Now</p>
      <h2 class="font-display text-3xl text-white mb-4">Schedule a Private Showing</h2>
      <p class="text-slate-400 text-sm mb-8">24-hour notice required. Daniel Issak accompanies all showings.</p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/contact" class="bg-amber-400 text-midnight-950 text-xs font-semibold tracking-widest uppercase px-8 py-4 hover:bg-amber-300 transition-colors amber-glow-hover">Contact Daniel →</a>
        <a href="tel:14242725935" class="border border-amber-400/40 text-amber-400 text-xs tracking-widest uppercase px-8 py-4 hover:border-amber-400 transition-colors">Call 424-272-5935</a>
      </div>
    </div>
  </section>
</Layout>
